import httpx
import logging
from app.config import settings

log = logging.getLogger(__name__)

async def send_otp_sms(phone: str, otp: str):
    """
    Send OTP via Fast2SMS.
    Phone should be 10 digits without country code e.g. 9876543210
    """
    # Strip country code if present
    clean_phone = phone.replace("+91", "").replace(" ", "").strip()

    if not settings.FAST2SMS_API_KEY:
        log.warning(f"[SMS] Fast2SMS key not set — OTP for {phone}: {otp}")
        return

    try:
        async with httpx.AsyncClient() as client:
            response = await client.post(
                "https://www.fast2sms.com/dev/bulkV2",
                headers={
                    "authorization": settings.FAST2SMS_API_KEY,
                    "Content-Type": "application/json",
                },
		
                json={
                    "route": "q",
                    "variables_values": otp,
                    "flash": 0,
                    "numbers": clean_phone,
                },
                timeout=10,
            )
            data = response.json()
            if data.get("return"):
                log.info(f"[SMS] OTP sent to {clean_phone}")
            else:
                log.error(f"[SMS] Failed to send OTP: {data}")
    except Exception as e:
        log.error(f"[SMS] Error sending OTP: {e}")
